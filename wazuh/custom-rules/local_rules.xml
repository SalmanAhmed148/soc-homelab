<group name="custom,windows,attack">
  <rule id="100001" level="12">
    <if_sid>60103</if_sid>
    <field name="win.eventdata.targetUserName">^Administrator$</field>
    <field name="win.eventdata.ipAddress">!^192\.168\.122\.</field>
    <description>Brute force attack detected: Multiple failed logins for Administrator from external IP</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
</group>
